---
import Base from '../layouts/Base.astro';
---
<Base title="goldfang">
  <section class="hero">
    <h1>goldfang</h1>
    <p class="tagline">building tools that respect the machine</p>
    <div class="links">
      <a href="https://github.com/realgoldfang">github</a>
      <span class="sep">/</span>
      <a href="/projects">projects</a>
      <span class="sep">/</span>
      <a href="/apt">apt repo</a>
    </div>
  </section>

  <section class="recent">
    <h2>recent work</h2>
    <div class="card">
      <h3><a href="/projects#mcp-sysd">mcp-sysd</a></h3>
      <p>systemd integration for MCP — manage services through natural language.</p>
      <span class="tag">golang</span>
      <span class="tag">systemd</span>
      <span class="tag">mcp</span>
    </div>
    <div class="card">
      <h3><a href="/projects#ad-wolf">ad-wolf</a></h3>
      <p>ad-blocker that doesn't respect the ad industry.</p>
      <span class="tag">dns</span>
      <span class="tag">linux</span>
    </div>
  </section>
</Base>

<style>
  .hero {
    padding: 4rem 0 3rem;
  }

  h1 {
    font-size: 2.5rem;
    font-family: var(--font-mono);
    color: var(--accent);
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.95rem;
  }

  .links a {
    color: var(--text);
    text-decoration: none;
  }

  .links a:hover {
    color: var(--accent);
  }

  .sep {
    color: var(--text-muted);
  }

  .recent h2 {
    margin-top: 0;
  }
</style>
