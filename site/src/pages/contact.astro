---
import Base from '../layouts/Base.astro';
---
<Base title="contact — goldfang">
  <h1>contact</h1>

  <div class="prose">
    <p>best way to reach me is github. open an issue or start a discussion.</p>

    <div class="links">
      <a href="https://github.com/realgoldfang" class="contact-link">
        <span class="icon">github</span>
        <span class="handle">@realgoldfang</span>
      </a>
    </div>

    <h2>pgp</h2>
    <p>
      if you need to encrypt something to me, my public key is on github:
      <a href="https://github.com/realgoldfang.gpg">github.com/realgoldfang.gpg</a>
    </p>
  </div>
</Base>

<style>
  .links {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin: 2rem 0;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    transition: border-color 0.2s;
  }

  .contact-link:hover {
    border-color: var(--accent-dim);
    text-decoration: none;
  }

  .icon {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    min-width: 5rem;
  }

  .handle { color: var(--text-muted); }
</style>
